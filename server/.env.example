# Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Format: postgresql://user:password@host:port/database
# Local: postgresql://admin:yourpassword@localhost:5432/yspm_timetable
# Docker: postgresql://admin:yourpassword@postgres:5432/yspm_timetable
DATABASE_URL=postgresql://admin:yourpassword@localhost:5432/yspm_timetable

# CORS Configuration
# In development: http://localhost:5173
# In production: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# Security
# Generate a secure random string for JWT secret if using JWT in future
# SECRET_KEY=your-secret-key-here
